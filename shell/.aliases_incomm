### -----------------------------------------------------------------------------------------------------###
### Function to backup files
## Create a backup file based on ISO 8601 (Year-Month-Day-Hour:Minutes:Seconds)
backup_files() {
    if [ -z "$1" ]; then
        echo "Inform the file to be backuped..."
        echo
        return 1
    fi

cp -p $1 $1.$(date "+%Y-%m-%d-%H:%M:%S")
}
alias bkp="backup_files"
